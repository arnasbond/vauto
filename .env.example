# Optional: personal OpenAI key for local dev only (production uses Vercel OPENAI_API_KEY)
# NEXT_PUBLIC_OPENAI_API_KEY=sk-your-key-here

# --- Express + PostgreSQL backend (optional) ---
# Without this, the app uses localStorage (demo mode).
#
# Local development (.env.local):
# NEXT_PUBLIC_API_URL=http://localhost:4000
#
# Vercel Production (after Render Blueprint deploy):
# NEXT_PUBLIC_API_URL=https://vauto-api.onrender.com
# (no trailing slash — use your actual Render service URL)
# Redeploy Vercel after setting so the static export picks up the value.

# Vercel Dashboard → Settings → Environment Variables:
# OPENAI_API_KEY=sk-your-key-here  (Production, Preview, Development)

# Server (copy server/.env.example → server/.env for local API)
# DATABASE_URL=postgresql://vauto:vauto@localhost:5432/vauto
# OPENAI_API_KEY=sk-your-key-here
# PORT=4000

# --- Express + PostgreSQL backend (optional) ---
# Without this, the app uses localStorage (demo mode).
#
# Local development (.env.local):
# NEXT_PUBLIC_API_URL=http://localhost:4000
#
# Vercel Production (after Render Blueprint deploy):
# NEXT_PUBLIC_API_URL=https://vauto-api.onrender.com
# (no trailing slash — use your actual Render service URL)
# Redeploy Vercel after setting so the static export picks up the value.

# Vercel Dashboard → Settings → Environment Variables:
# Production AI runs via Render (NEXT_PUBLIC_API_URL) — do NOT set client Gemini in prod.
# Local offline dev only (optional):
# NEXT_PUBLIC_DEV_GEMINI=1
# NEXT_PUBLIC_GEMINI_API_KEY=your-gemini-key  (restrict to HTTP referrers)
# GEMINI_API_KEY=your-gemini-key  (optional server-side / legacy)
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=...  (Google One Tap)
# NEXT_PUBLIC_API_URL=https://vauto-api.onrender.com

# Render API (set in Render Dashboard — see server/.env.example):
# JWT_SECRET, GEMINI_API_KEY, VAPID_*, FIREBASE_SERVICE_ACCOUNT_JSON, TWILIO_*, GOOGLE_CLIENT_ID

# Server (copy server/.env.example → server/.env for local API)
# DATABASE_URL=postgresql://vauto:vauto@localhost:5432/vauto
# GEMINI_API_KEY=your-gemini-key
# PORT=4000

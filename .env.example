# Optional: OpenAI API key for web dev (mobile app uses Profilis → AI nustatymai)
# NEXT_PUBLIC_OPENAI_API_KEY=sk-your-key-here

# Backend API (when set, app syncs with PostgreSQL instead of localStorage only)
# NEXT_PUBLIC_API_URL=http://localhost:4000

# Server (.env in server/ folder)
# DATABASE_URL=postgresql://vauto:vauto@localhost:5432/vauto
# OPENAI_API_KEY=sk-your-key-here
# PORT=4000

# Optional: personal OpenAI key for local dev only (production uses Vercel OPENAI_API_KEY)
# NEXT_PUBLIC_OPENAI_API_KEY=sk-your-key-here

# Optional: Express + PostgreSQL backend (separate from AI proxy)
# NEXT_PUBLIC_API_URL=http://localhost:4000

# Vercel Dashboard → Settings → Environment Variables:
# OPENAI_API_KEY=sk-your-key-here  (Production, Preview, Development)

# Server (.env in server/ folder)
# DATABASE_URL=postgresql://vauto:vauto@localhost:5432/vauto
# OPENAI_API_KEY=sk-your-key-here
# PORT=4000

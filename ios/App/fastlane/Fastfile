# Fastlane lanes for autonomous TestFlight + ad-hoc sideload builds.
# Required GitHub Secrets (TestFlight): APPSTORE_KEY_ID, APPSTORE_ISSUER_ID,
# APPSTORE_PRIVATE_KEY (base64 .p8), APPLE_TEAM_ID, BUILD_CERTIFICATE_BASE64,
# P12_PASSWORD, BUILD_PROVISION_PROFILE_BASE64

default_platform(:ios)

def asc_api_key
  app_store_connect_api_key(
    key_id: ENV.fetch("APPSTORE_KEY_ID"),
    issuer_id: ENV.fetch("APPSTORE_ISSUER_ID"),
    key_content: ENV.fetch("APPSTORE_PRIVATE_KEY"),
    is_key_content_base64: true
  )
end

platform :ios do
  before_all do
    setup_ci if ENV["CI"]
  end

  desc "Signed App Store build + upload to TestFlight (fully autonomous after secrets setup)"
  lane :beta do
    api_key = asc_api_key

    increment_build_number(
      xcodeproj: "App.xcodeproj",
      build_number: ENV.fetch("GITHUB_RUN_NUMBER", Time.now.to_i.to_s)
    )

    build_app(
      workspace: "App.xcworkspace",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "com.vauto.app" => ENV.fetch("IOS_PROVISIONING_PROFILE_NAME", "Vauto App Store")
        }
      },
      output_directory: "./build",
      output_name: "vauto-testflight.ipa",
      clean: true
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      notify_external_testers: false
    )

    UI.success("TestFlight upload started. Check App Store Connect → TestFlight.")
  end

  desc "Ad-hoc signed IPA for registered iPhone UDIDs (OTA sideload, no TestFlight)"
  lane :adhoc do
    increment_build_number(
      xcodeproj: "App.xcodeproj",
      build_number: ENV.fetch("GITHUB_RUN_NUMBER", Time.now.to_i.to_s)
    )

    build_app(
      workspace: "App.xcworkspace",
      scheme: "App",
      configuration: "Release",
      export_method: "ad-hoc",
      export_options: {
        provisioningProfiles: {
          "com.vauto.app" => ENV.fetch("IOS_ADHOC_PROFILE_NAME", "Vauto Ad Hoc")
        }
      },
      output_directory: "./build",
      output_name: "vauto-adhoc.ipa",
      clean: true
    )
  end
end

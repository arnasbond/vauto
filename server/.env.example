# Local Docker / docker compose
DATABASE_URL=postgresql://vauto:vauto@localhost:5432/vauto
PORT=4000

# Auth (required for production)
# JWT_SECRET=generate-a-long-random-string
# ADMIN_EMAIL=admin@vauto.com
# ADMIN_PHONE=+37060000099
# VAUTO_DEMO_OTP=123456
# VAUTO_ALLOW_DEMO_WALLET=true

# Ops/QA route protection (production) — required header X-Vauto-Ops-Secret for
# POST /api/bootstrap and GET /api/test/e2e-simulation. Without it those routes 404 in prod.
# VAUTO_OPS_SECRET=generate-a-long-random-string

# AI (Gemini only)
# GEMINI_API_KEY=your-gemini-key
# AI_KEY=your-gemini-key

# Rate limits (per IP or user id, per minute) — raise for beta if users share NAT/CGNAT.
# Defaults below match server code; API is the general read tier (listings, chats,
# notifications, preferences) so it must be generous for a read-heavy SPA.
# API_RATE_LIMIT_PER_MIN=300
# ACTION_RATE_LIMIT_PER_MIN=120
# SEARCH_RATE_LIMIT_PER_MIN=40
# AI_RATE_LIMIT_PER_MIN=30
# AUTH_RATE_LIMIT_PER_MIN=60

# Cross-domain (anonser.lt ↔ vauto.anonser.lt):
# Current auth uses JWT Bearer in localStorage + token handoff (?vauto_token=).
# CORS origin:true without credentials is sufficient for this model.
# Future cookie-based session (.anonser.lt Domain cookie) would require:
#   CORS_ALLOWED_ORIGINS=https://anonser.lt,https://vauto.anonser.lt
#   credentials:true on server + credentials:include on client fetches.
# CORS_ALLOWED_ORIGINS=

# Web Push (VAPID) — generate: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@vauto.lt

# FCM Android — Firebase Console → Service accounts → JSON
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# SMS OTP (Twilio)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+1234567890

# ADMIN_NOTIFY_EMAIL=admin@vauto.com,projekto@example.lt
# EMAIL_FROM=Vauto <noreply@yourdomain.lt>
# APP_ORIGIN — canonical frontend URL (e.g. https://www.vauto.lt).
# The API host uses it to redirect any non-/api browser hit to the real site,
# so the root never shows "Cannot GET /".
# APP_ORIGIN=https://www.vauto.lt
# NEXT_PUBLIC_ANONSER_URL=https://anonser.lt
# NEXT_PUBLIC_VAUTO_URL=https://www.vauto.lt
# NEXT_PUBLIC_ANONSER_LOGO_URL=https://anonser.lt/wp-content/uploads/logo.png

# Single-service hosting (optional): if you build the Next.js static export
# (`npm run build` → out/) into the API image, point STATIC_DIR at it and the
# Express server will serve the frontend directly instead of redirecting.
# STATIC_DIR=/app/out
# RESEND_API_KEY=re_...

# Stripe (test: sk_test_... from dashboard.stripe.com → Developers → API keys)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_AUTO_WEBHOOK=1
# PUBLIC_API_URL=https://vauto-api.onrender.com

# LT plate lookup (Regitra register data via licensed third-party API)
# REGITRA_PLATE_API_USERNAME=
# REGITRA_PLATE_API_PASSWORD=
# REGITRA_PLATE_API_URL=https://www.numeriozenklaiapi.lt/api/reg.asmx

# Visual AI Pipeline (v1.6.17) — pirmas sukonfigūruotas provider laimi
# Background removal (vienas iš):
# PHOTOROOM_API_KEY=
# CLIPDROP_API_KEY=
# REMOVEBG_API_KEY=

# OCR (pirmas sukonfigūruotas):
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GOOGLE_CLOUD_VISION_CREDENTIALS_JSON={"type":"service_account",...}
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-central-1
# Optional CPU fallback when no cloud OCR is configured. Use carefully on small Render plans.
# TESSERACT_OCR_ENABLED=1

# Shipping carriers — Omniva OMX (production) + DPD
# Omniva: HTTP Basic Auth (account manager credentials)
# OMNIVA_USERNAME=
# OMNIVA_PASSWORD=
# OMNIVA_CUSTOMER_CODE=   # optional; defaults to OMNIVA_USERNAME
# OMNIVA_API_URL=https://omx.omniva.eu/api/v01/omx   # production only; test-omx blocked unless OMNIVA_ALLOW_TEST_ENV=1
# Legacy aliases (optional): OMNIVA_API_USERNAME, OMNIVA_API_KEY (as password)
# DPD_API_KEY=
# DPD_API_URL=https://api.dpd.lt

# Render (render.yaml Blueprint):
# - DATABASE_URL and PORT are injected automatically
# - Set other keys manually in Render Dashboard (sync: false in blueprint)

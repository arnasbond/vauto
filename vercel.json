{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "out",
  "env": {
    "NEXT_PUBLIC_API_URL": "https://vauto-api.onrender.com"
  },
  "build": {
    "env": {
      "NEXT_PUBLIC_API_URL": "https://vauto-api.onrender.com"
    }
  },
  "rewrites": [
    {
      "source": "/listing/:slug",
      "destination": "/listing/index.html?slug=:slug"
    },
    {
      "source": "/listing/:slug/",
      "destination": "/listing/index.html?slug=:slug"
    }
  ],
  "headers": [
    {
      "source": "/profile/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, must-revalidate" }]
    },
    {
      "source": "/admin/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, must-revalidate" }]
    },
    {
      "source": "/(.*)index.txt",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        },
        {
          "key": "Cache-Control",
          "value": "private, no-store"
        }
      ]
    }
  ]
}

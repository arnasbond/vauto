{
  "name": "vauto",
  "version": "1.6.62",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/generate-sitemap.mjs && next build",
    "build:e2e": "node scripts/build-e2e-static.mjs",
    "build:clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && npm run build",
    "start": "next start",
    "lint": "next lint",
    "test:e2e": "npm run build:e2e && playwright test",
    "test:e2e:conductor": "node scripts/build-with-conductor.mjs && playwright test e2e/ai-conductor.spec.ts",
    "test:e2e:conductor-runtime": "npm run build:e2e && playwright test e2e/ai-conductor-runtime.spec.ts",
    "test:e2e:conductor-runtime-live": "npm run sync:runtime-config:conductor && npm run build:e2e && playwright test e2e/ai-conductor-runtime-live.spec.ts",
    "test:e2e:conductor-off": "npm run build:e2e && playwright test e2e/ai-conductor-off.spec.ts",
    "test:e2e:install": "playwright install chromium",
    "build:mobile": "next build",
    "cap:assets": "npx capacitor-assets generate --android",
    "cap:sync": "npx cap sync android",
    "cap:sync:ios": "npx cap sync ios",
    "cap:open": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "apk": "powershell -ExecutionPolicy Bypass -File scripts/build-apk.ps1",
    "ios:stage2": "node _later/ios-testflight/setup-ios-testflight.mjs --check",
    "server:install": "npm install --prefix server",
    "server:dev": "npm run dev --prefix server",
    "server:build": "npm run build --prefix server",
    "server:start": "npm run start --prefix server",
    "db:up": "docker compose up -d",
    "db:seed": "npm run seed --prefix server",
    "db:purge-ai-test": "node server/scripts/purge-ai-test-listings.mjs",
    "db:purge-ai-test:dry": "node server/scripts/purge-ai-test-listings.mjs --dry-run",
    "pitch:pdf": "node scripts/generate-pitch-pdf.mjs",
    "report:launch-pdf": "node scripts/generate-launch-readiness-pdf.mjs",
    "report:emotional-pdf": "node scripts/generate-emotional-experience-pdf.mjs",
    "test:emotional": "node scripts/test-emotional-experience.mjs",
    "test:p1p2": "node scripts/test-p1-p2-emotional.mjs",
    "test:adaptive": "node scripts/test-adaptive-layout.mjs",
    "test:universal-search": "npm run server:build && node scripts/test-universal-search-stress.mjs",
    "verify:gemini-live": "node scripts/verify-gemini-live.mjs",
    "provision:render": "node scripts/provision-render.mjs",
    "redeploy:render": "node scripts/redeploy-render.mjs",
    "render:stripe-env": "node scripts/set-render-stripe-env.mjs",
    "render:configure-env": "node scripts/configure-render-env.mjs",
    "verify:health": "node scripts/verify-health.mjs",
    "verify:infra": "node scripts/verify-infra-readiness.mjs",
    "test:visual-pipeline-qa": "npm run server:build && npm run test:visual-pipeline-qa --prefix server",
    "validate:catalogs": "node scripts/validate-catalogs.mjs",
    "verify:health:strict": "node scripts/verify-health.mjs --strict-readiness",
    "verify:carriers": "node scripts/verify-carriers.mjs",
    "verify:carriers:local": "node scripts/verify-carriers.mjs --local",
    "verify:production-soak": "node scripts/verify-production-soak.mjs",
    "drill:conductor-kill-switch": "node scripts/conductor-kill-switch-drill.mjs",
    "sync:runtime-config": "node scripts/write-runtime-config.mjs",
    "sync:runtime-config:conductor": "node scripts/sync-runtime-config-conductor.mjs",
    "test:api-smoke": "node scripts/api-listing-smoke.mjs",
    "test:api-integration": "node scripts/verify-health.mjs && node scripts/api-listing-smoke.mjs",
    "audit:security": "node scripts/audit-security.mjs",
    "test:server-smoke": "npm run server:build && node scripts/validation-smoke.mjs && node scripts/critical-smoke.mjs",
    "test:auth-e2e": "npm run server:build && node scripts/test-auth-e2e.mjs",
    "test:auth-e2e:live": "npm run server:build && node scripts/test-auth-e2e.mjs --live",
    "ops:auth-reset": "node scripts/auth-reset.mjs",
    "test:ai-flexibility": "npm run server:build && node scripts/test-ai-flexibility.mjs",
    "test:ai-flexibility:local": "npm run server:build && node scripts/test-ai-flexibility.mjs --local",
    "test:wardrobe-flow": "npm run server:build && node scripts/test-wardrobe-flow.mjs",
    "test:wardrobe-flow:local": "npm run server:build && node scripts/test-wardrobe-flow.mjs --local",
    "test:business-flow": "npm run server:build && node scripts/test-business-flow.mjs",
    "test:business-flow:local": "npm run server:build && node scripts/test-business-flow.mjs --local",
    "test:realtime": "npm run server:build && node scripts/test-realtime-notifications.mjs",
    "test:realtime:local": "npm run server:build && node scripts/test-realtime-notifications.mjs --local",
    "sim:e2e": "npm run e2e:simulate --prefix server",
    "generate:mock-catalog": "node scripts/generate-mock-catalog.mjs",
    "generate:sitemap": "node scripts/generate-sitemap.mjs",
    "audit:catalog": "node scripts/audit-catalog.mjs",
    "audit:images": "node scripts/check-unsplash-urls.mjs",
    "validate:fast-search": "node scripts/validate-fast-search.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.3",
    "@capacitor/camera": "^6.1.2",
    "@capacitor/core": "^6.2.1",
    "@capacitor/geolocation": "^6.1.0",
    "@capacitor/haptics": "^6.0.3",
    "@capacitor/ios": "^6.2.1",
    "@capacitor/preferences": "^6.0.4",
    "@capacitor/push-notifications": "^6.0.4",
    "@capacitor/share": "^6.0.4",
    "@capacitor/splash-screen": "^6.0.3",
    "@capacitor/status-bar": "^6.0.2",
    "commander": "^12.1.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.511.0",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^9.1.0",
    "supercluster": "^8.0.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.2.1",
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@types/supercluster": "^7.1.3",
    "@vercel/node": "^5.8.17",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.19",
    "playwright": "^1.61.0",
    "tailwindcss": "^4.1.8",
    "tr46": "^5.1.1",
    "typescript": "^5.8.3"
  },
  "capacitor": {
    "platforms": [
      "android",
      "ios"
    ]
  }
}
